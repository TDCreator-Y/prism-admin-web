{
  "name": "dashboard-lightweight-template",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=8.15.0 <9"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "build-only": "vite build",
    "lint": "eslint . --ext .ts,.vue --cache",
    "lint:fix": "pnpm lint --fix",
    "type-check": "vue-tsc --build",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "e2e": "pnpm build && playwright test",
    "e2e:ci": "pnpm build && playwright test --project=chromium",
    "e2e:headed": "pnpm build && playwright test --headed --project=chromium",
    "e2e:ui": "pnpm build && playwright test --ui --project=chromium",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.15.32",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.4.35",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  }
}
